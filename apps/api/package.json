{
  "name": "@app/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/server.ts",
  "scripts": {
    "build": "tsc --build",
    "typecheck": "tsc --noEmit",
    "dev": "tsx watch src/server.ts",
    "lint": "eslint .",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo",
    "db:generate": "prisma generate --schema=../../prisma/schema.prisma --env-file=../../.env",
    "db:validate": "prisma validate --schema=../../prisma/schema.prisma --env-file=../../.env",
    "db:format": "prisma format --schema=../../prisma/schema.prisma --env-file=../../.env"
  },
  "prisma": {
    "schema": "../../prisma/schema.prisma"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@prisma/client": "^6.19.3",
    "@supabase/supabase-js": "^2.106.0",
    "@trpc/server": "^11.17.0",
    "fastify": "^5.2.0",
    "superjson": "^2.2.6"
  },
  "devDependencies": {
    "@types/node": "^22.13.0",
    "prisma": "^6.19.3",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
