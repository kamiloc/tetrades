# ============================================================
# apps/api — Required environment variables
# Copy this file to .env and fill in real values.
# NEVER commit .env to source control.
# ============================================================

# PostgreSQL connection string (Supabase project > Settings > Database > Connection string)
DATABASE_URL=postgresql://postgres:[password]@[host]:5432/postgres

# Direct URL for Prisma migrations (bypasses PgBouncer connection pooling)
DIRECT_URL=postgresql://postgres:[password]@[host]:5432/postgres

# Supabase project URL
SUPABASE_URL=https://your-project.supabase.co

# Supabase anonymous (public) key — safe to expose to browsers
SUPABASE_ANON_KEY=your-anon-key

# Allowed CORS origin for the web / mobile dev server
CORS_ORIGIN=http://localhost:3000

# API server port (optional — defaults to 3001)
# API_PORT=3001

# Node environment
NODE_ENV=development

# 64-character hex string (32 random bytes) used for AES-256-GCM envelope encryption
# of all L2-CONFIDENTIAL fields. Generate a new key with:
#   openssl rand -hex 32
# L3-RESTRICTED: NEVER commit the real value. NEVER log or expose this key.
MASTER_ENCRYPTION_KEY=<replace-with-output-of-openssl-rand-hex-32>

# Upstash Redis — ioredis connection used by BullMQ queues/workers and the
# Redis-backed rate limiter. Upstash is TLS-only, so the scheme is rediss://.
# L3-RESTRICTED: the URL embeds the access token. NEVER commit or log it.
# Optional in development/test (falls back to in-memory rate limiting, no
# workers); REQUIRED in production.
UPSTASH_REDIS_URL=rediss://default:<token>@<host>:<port>

# BullMQ worker concurrency overrides (optional, defaults shown)
WORKER_CONCURRENCY_OCR=1
WORKER_CONCURRENCY_IMAGE=2
WORKER_CONCURRENCY_PII=1
WORKER_CONCURRENCY_NOTIFICATIONS=5
