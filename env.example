# ============================================
# The Athlete Passport — Environment Variables
# ============================================
# Copy this file to .env and fill in real values.
# NEVER commit .env to git. Only .env.example is tracked.
#
# Classification reminder:
#   All values in .env are L3-RESTRICTED.
#   Never log, echo, or expose them in error messages.
# ============================================

# ──────────────────────────────────────────────
# SUPABASE — Core
# ──────────────────────────────────────────────

# Project URL (found in Supabase Dashboard → Settings → API)
SUPABASE_URL="https://your-project-id.supabase.co"

# Anonymous key — safe for client-side use, respects RLS
SUPABASE_ANON_KEY="eyJ..."

# Service role key — BYPASSES RLS. Server-side only.
# Used by: background jobs, break-glass access, constraint scripts
SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# ──────────────────────────────────────────────
# SUPABASE — Database (Prisma)
# ──────────────────────────────────────────────

# Pooled connection via pgBouncer (port 6543) — used by the application
# Format: postgresql://postgres.[project-ref]:[password]@[host]:6543/postgres?pgbouncer=true
DATABASE_URL="postgresql://postgres.your-project-ref:your-password@aws-0-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=10"

# Direct connection (port 5432) — used by Prisma migrations only
# Format: postgresql://postgres.[project-ref]:[password]@[host]:5432/postgres
DIRECT_URL="postgresql://postgres.your-project-ref:your-password@aws-0-us-east-1.pooler.supabase.com:5432/postgres"

# ──────────────────────────────────────────────
# SUPABASE — Client-side (exposed to browser/app)
# ──────────────────────────────────────────────

# Next.js public variables (NEXT_PUBLIC_ prefix required)
NEXT_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Expo public variables (EXPO_PUBLIC_ prefix required)
EXPO_PUBLIC_SUPABASE_URL="https://your-project-id.supabase.co"
EXPO_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# ──────────────────────────────────────────────
# ENCRYPTION — @packages/crypto
# ──────────────────────────────────────────────

# 256-bit master encryption key for envelope encryption (AES-256-GCM)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# This key wraps per-record data encryption keys (DEKs).
MASTER_ENCRYPTION_KEY="generate-a-64-char-hex-string-here"

# ──────────────────────────────────────────────
# ANTHROPIC — Medical OCR (Claude Vision)
# ──────────────────────────────────────────────

# API key for Claude Sonnet (used by processOCR background job)
ANTHROPIC_API_KEY="sk-ant-..."

# ──────────────────────────────────────────────
# REDIS — BullMQ Background Jobs
# ──────────────────────────────────────────────

# Redis connection URL (Upstash, Railway Redis, or self-hosted)
REDIS_URL="redis://default:your-password@your-redis-host:6379"

# ──────────────────────────────────────────────
# APPLICATION
# ──────────────────────────────────────────────

# Runtime environment
NODE_ENV="development"

# API server port (Fastify)
API_PORT="3001"

# Public web URL (for CORS, Magic Link redirects, OG images)
WEB_URL="http://localhost:3000"

# Mobile deep link scheme (for Magic Link redirects to Expo)
MOBILE_SCHEME="athletepassport"

# Cross Origin Requests
CORS_ORIGIN=

# ──────────────────────────────────────────────
# OBSERVABILITY (Sprint 8)
# ──────────────────────────────────────────────

# Sentry DSN — error tracking (leave empty until Sprint 8)
# SENTRY_DSN=""

# PostHog API key — product analytics (leave empty until Sprint 8)
# POSTHOG_API_KEY=""
# POSTHOG_HOST="https://app.posthog.com"
